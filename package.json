{
    "name": "pull-before-edit",
    "displayName": "Pull Before Edit",
    "description": "Prevents editing until you pull remote changes from GitHub",
    "version": "1.0.2",
    "publisher": "kht",
    "engines": {
        "vscode": "^1.85.0"
    },
    "categories": [
        "Other"
    ],
    "activationEvents": [
        "onStartupFinished",
        "workspaceContains:**/.git"
    ],
    "main": "extension.js",
    "repository": {
        "type": "git",
        "url": "https://github.com/YOUR_USERNAME/pull-before-edit"
    }
}